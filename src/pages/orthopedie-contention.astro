---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Meilleur Orthopédie et Contention | Solutions Efficaces";
const description = "Besoin d'orthopédie et de contention ? Découvrez nos solutions efficaces et innovantes pour votre bien-être et votre santé.";
---

<Layout title={title} description={description}>
  <Header />
  
  <main class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-16" data-aos="fade-down">
        <h1 class="text-4xl md:text-5xl font-bold font-heading mb-6 text-primary-700 dark:text-primary-400">
          Orthopédie et Contention
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          Solutions textiles efficaces et innovantes qui agissent sur le bien-être et la santé des femmes et des hommes.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 mb-16">
        <div class="p-8 bg-blue-50 dark:bg-blue-900/10 rounded-3xl border border-blue-100 dark:border-blue-800" data-aos="fade-right">
          <img src="/images/2024/04/contention-1350x650-1.jpg" alt="Contention" class="rounded-2xl mb-6 shadow-md" />
          <h2 class="text-2xl font-bold mb-4">Nos Partenaires</h2>
          <div class="space-y-4">
            <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-800 rounded-xl">
              <span class="font-bold">DonJoy</span>
              <a href="https://www.djoglobal.com/our-brands/donjoy" class="text-primary-600 text-sm font-bold" target="_blank">Catalogue →</a>
            </div>
            <div class="flex items-center justify-between p-4 bg-white dark:bg-gray-800 rounded-xl">
              <span class="font-bold">SIGVARIS</span>
              <a href="https://www.sigvaris.com/fr-fr/catalogue" class="text-primary-600 text-sm font-bold" target="_blank">Catalogue →</a>
            </div>
          </div>
        </div>

        <div class="p-8 bg-purple-50 dark:bg-purple-900/10 rounded-3xl border border-purple-100 dark:border-purple-800" data-aos="fade-left">
          <h2 class="text-2xl font-bold mb-6">Oxypharm & Vitadomia</h2>
          <div class="aspect-square rounded-2xl overflow-hidden shadow-inner bg-white">
            <iframe src="https://www.vitadomia.com/-/grand-public/tous-nos-produits" class="w-full h-full border-0"></iframe>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
