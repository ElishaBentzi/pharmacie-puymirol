---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Téléconsultation | Diagnostic et Traitement Rapides";
const description = "Vous cherchez un accès rapide à un médecin ? Notre pharmacie propose des téléconsultations via la plateforme Medadom.";
---

<Layout title={title} description={description}>
  <Header />
  
  <main class="py-16 bg-white dark:bg-gray-900">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-8 text-primary-700 dark:text-primary-400" data-aos="fade-down">
        Téléconsultation
      </h1>
      
      <div class="grid md:grid-cols-2 gap-12 mb-16 items-center">
        <div data-aos="fade-right">
          <h2 class="text-2xl font-bold mb-4">Service de télémédecine en pharmacie</h2>
          <p class="text-gray-600 dark:text-gray-300 mb-6">
            Notre pharmacie offre la possibilité de téléconsultations avec des médicos via la plateforme <strong>Medadom</strong>. 
            Medadom vous met en relation avec des médecins généralistes et spécialistes en temps réel.
          </p>
          <div class="bg-primary-50 dark:bg-primary-900/20 p-6 rounded-xl border border-primary-100 dark:border-primary-800">
            <h3 class="font-bold mb-3">Avantages:</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex gap-2"><span>✅</span> Accès immédiat aux soins médicaux</li>
              <li class="flex gap-2"><span>✅</span> Soins sans rendez-vous</li>
              <li class="flex gap-2"><span>✅</span> Variété de spécialités</li>
              <li class="flex gap-2"><span>✅</span> Service personnalisé et de qualité</li>
            </ul>
          </div>
        </div>
        <div data-aos="zoom-in">
          <img src="/images/2024/04/medadom-puymirol.jpg" alt="Borne Medadom Puymirol" class="rounded-2xl shadow-xl w-full" />
        </div>
      </div>

      <div class="bg-gray-50 dark:bg-gray-800 p-8 rounded-3xl mb-16" data-aos="fade-up">
        <h2 class="text-2xl font-bold mb-6 text-center">Comment ça marche?</h2>
        <div class="grid md:grid-cols-4 gap-6 font-medium text-center">
          <div class="space-y-3">
            <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center mx-auto text-xl">1</div>
            <p class="text-sm">Demandez une téléconsultation</p>
          </div>
          <div class="space-y-3">
            <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center mx-auto text-xl">2</div>
            <p class="text-sm">Mise en contact via l'appareil</p>
          </div>
          <div class="space-y-3">
            <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center mx-auto text-xl">3</div>
            <p class="text-sm">Diagnostic personnalisé</p>
          </div>
          <div class="space-y-3">
            <div class="w-12 h-12 bg-primary-600 text-white rounded-full flex items-center justify-center mx-auto text-xl">4</div>
            <p class="text-sm">Prescription et conseils</p>
          </div>
        </div>
      </div>

      <div class="border-t border-gray-100 dark:border-gray-800 pt-12 text-center" data-aos="fade-up">
        <h2 class="text-2xl font-bold mb-6">Zone de service</h2>
        <div class="flex flex-wrap justify-center gap-2">
          {["Puymirol", "Lafox", "Tayrac", "Grayssas", "Perville", "Casteljaloux", "Saint-Urcisse", "Saint-Romain-le-Noble", "Saint-Caprais-de-Lerm"].map(city => (
            <span class="px-4 py-1 bg-gray-100 dark:bg-gray-700 rounded-full text-sm">{city}</span>
          ))}
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
