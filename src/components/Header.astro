---
import { pharmacyData } from '../data/store';

const navItems = [
  { href: '/', label: 'Accueil' },
  { href: '/teleconsultation', label: 'Téléconsultation' },
  { href: '/materiel-medical', label: 'Matériel Médical' },
  { href: '/orthopedie-contention', label: 'Orthopédie et Contention' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 dark:bg-gray-900/95 backdrop-blur-md shadow-sm border-b border-gray-100 dark:border-gray-800" role="banner">
  <nav class="container mx-auto px-4" aria-label="Navigation principale">
    <div class="flex items-center justify-between h-20">
      <!-- Logo Real -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0" aria-label={`${pharmacyData.name} - Retour à l'accueil`}>
        <img 
          src="/images/logos/logo-menu.png" 
          alt="Pharmacie Puymirol"
          width="200"
          height="64"
          class="h-14 w-auto object-contain"
          loading="eager"
          fetchpriority="high"
        />
      </a>
      
      <!-- Desktop Navigation -->
      <ul class="hidden lg:flex items-center gap-8" role="menubar">
        {navItems.map((item) => (
          <li role="none">
            <a 
              href={item.href}
              role="menuitem"
              aria-current={currentPath === item.href ? 'page' : undefined}
              class:list={[
                'relative py-2 text-sm font-medium transition-all duration-300 group',
                'after:absolute after:bottom-0 after:left-0 after:w-0 after:h-0.5 after:bg-pharmacy-gradient after:transition-all after:duration-300 hover:after:w-full',
                currentPath === item.href 
                  ? 'text-pharmacy-700 dark:text-pharmacy-400 after:w-full font-semibold' 
                  : 'text-gray-700 dark:text-gray-300 hover:text-pharmacy-600 dark:hover:text-pharmacy-400'
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      
      <!-- Right side -->
      <div class="flex items-center gap-3">
        <!-- Phone CTA (desktop) -->
        <a 
          href={`tel:${pharmacyData.contact.phoneHref}`}
          class="hidden md:inline-flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-pharmacy-600 to-health-500 text-white text-sm font-semibold rounded-full shadow-pharmacy hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-300"
          aria-label="Appeler la pharmacie"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {pharmacyData.contact.phone}
        </a>

        <!-- Dark mode toggle -->
        <button 
          id="theme-toggle"
          class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Changer le thème clair/sombre"
          title="Thème clair/sombre"
        >
          <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"></path>
          </svg>
          <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"></path>
          </svg>
        </button>
        
        <!-- Mobile menu button -->
        <button 
          id="mobile-menu-btn"
          class="lg:hidden p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label="Ouvrir le menu de navigation"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
    
    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4" role="menu" aria-label="Menu mobile">
      <ul class="flex flex-col gap-1 pt-2 border-t border-gray-100 dark:border-gray-800">
        {navItems.map((item) => (
          <li role="none">
            <a 
              href={item.href}
              role="menuitem"
              aria-current={currentPath === item.href ? 'page' : undefined}
              class:list={[
                'block px-4 py-3 rounded-lg text-base font-medium transition-colors',
                currentPath === item.href 
                  ? 'text-pharmacy-700 dark:text-pharmacy-400 bg-pharmacy-50 dark:bg-pharmacy-900/20' 
                  : 'text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800'
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li class="pt-2 px-4">
          <a href={`tel:${pharmacyData.contact.phoneHref}`} class="flex items-center justify-center gap-2 w-full py-3 bg-gradient-to-r from-pharmacy-600 to-health-500 text-white font-semibold rounded-lg">
            📞 {pharmacyData.contact.phone}
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  
  mobileMenuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.toggle('hidden');
    mobileMenuBtn?.setAttribute('aria-expanded', String(!isHidden));
  });
  
  const themeToggle = document.getElementById('theme-toggle');
  
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
</script>
