---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-100 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Contact Info -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-primary-700 dark:text-primary-400">Contact</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <span class="text-gray-600 dark:text-gray-300">32 rue Royale<br>47270 PUYMIROL</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <a href="tel:0966111427" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">09 66 11 14 27</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <a href="mailto:pharmaciepuymirol@gmail.com" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">pharmaciepuymirol@gmail.com</a>
          </li>
        </ul>
      </div>
      
      <!-- Opening Hours -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-primary-700 dark:text-primary-400">Horaires</h3>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300">
          <li class="flex justify-between">
            <span>Lundi</span>
            <span>8:45 - 12:30 / 14:00 - 19:30</span>
          </li>
          <li class="flex justify-between">
            <span>Mardi</span>
            <span>8:45 - 12:30 / 14:00 - 19:30</span>
          </li>
          <li class="flex justify-between">
            <span>Mercredi</span>
            <span>8:45 - 12:30 / 14:00 - 19:00</span>
          </li>
          <li class="flex justify-between">
            <span>Jeudi</span>
            <span>8:45 - 12:30 / 14:00 - 19:30</span>
          </li>
          <li class="flex justify-between">
            <span>Vendredi</span>
            <span>8:45 - 12:30 / 14:00 - 19:30</span>
          </li>
          <li class="flex justify-between">
            <span>Samedi</span>
            <span>9:00 - 12:00</span>
          </li>
          <li class="flex justify-between text-red-600 dark:text-red-400">
            <span>Dimanche</span>
            <span>Fermé</span>
          </li>
        </ul>
      </div>
      
      <!-- Services -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-primary-700 dark:text-primary-400">Services</h3>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="/teleconsultation" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Téléconsultation</a>
          </li>
          <li>
            <a href="/materiel-medical" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Matériel Médical</a>
          </li>
          <li>
            <a href="/orthopedie-contention" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">Orthopédie et Contention</a>
          </li>
        </ul>
      </div>
    </div>
    
    <!-- Bottom bar -->
    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700 text-center text-sm text-gray-500 dark:text-gray-400">
      <p>&copy; {currentYear} Pharmacie Puymirol. Tous droits réservés.</p>
    </div>
  </div>
</footer>
