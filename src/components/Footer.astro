---
import { pharmacyData } from '../data/store';
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-100 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700" role="contentinfo">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Contact Info -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-primary-700 dark:text-primary-400">Contact</h3>
        <ul class="space-y-3 text-sm" aria-label="Informations de contact">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <address class="not-italic text-gray-600 dark:text-gray-300">
              {pharmacyData.contact.address}<br />
              {pharmacyData.contact.zipCode} {pharmacyData.contact.city}
            </address>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            <a href={`tel:${pharmacyData.contact.phoneHref}`} class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">{pharmacyData.contact.phone}</a>
          </li>
          <li class="flex items-center gap-3">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
            <a href={`mailto:${pharmacyData.contact.email}`} class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400">{pharmacyData.contact.email}</a>
          </li>
        </ul>
      </div>
      
      <!-- Opening Hours -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-primary-700 dark:text-primary-400">Horaires</h3>
        <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300" aria-label="Heures d'ouverture">
          {pharmacyData.hours.map((h) => (
            <li class={`flex justify-between ${h.closed ? 'text-red-600 dark:text-red-400' : ''}`}>
              <span>{h.day}</span>
              <span>{h.hours}</span>
            </li>
          ))}
        </ul>
      </div>
      
      <!-- Services -->
      <div>
        <h3 class="font-heading font-semibold text-lg mb-4 text-primary-700 dark:text-primary-400">Services</h3>
        <ul class="space-y-2 text-sm" aria-label="Nos services">
          {pharmacyData.services.map((s) => (
            <li>
              <a href={s.href} class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">{s.name}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
    <!-- Bottom bar -->
    <div class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700 text-center text-sm text-gray-500 dark:text-gray-400">
      <p>&copy; {currentYear} {pharmacyData.name}. Tous droits réservés.</p>
      <p class="mt-1 text-xs">{pharmacyData.slogan} — Depuis {pharmacyData.since}</p>
    </div>
  </div>
</footer>
